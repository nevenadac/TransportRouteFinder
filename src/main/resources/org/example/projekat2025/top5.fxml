<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.projekat2025.controller.Top5RoutesController"
            prefHeight="400.0" prefWidth="600.0">

    <TableView fx:id="routesTable" prefHeight="300">
        <columns>
            <TableColumn fx:id="totalTime" text="Total Time"/>
            <TableColumn fx:id="totalPrice" text="Total Price"/>
            <TableColumn fx:id="totalTransferNumber" text="Total Transfers"/>
            <TableColumn fx:id="actionColumn" text="Action" />
        </columns>
    </TableView>


</VBox>
