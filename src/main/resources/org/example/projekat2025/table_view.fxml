<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>


<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.projekat2025.controller.TableViewController">

    <center>
        <VBox spacing="10" BorderPane.alignment="CENTER">
            <TableView fx:id="routeTable" prefHeight="200.0">
                <columns>
                    <TableColumn fx:id="colFrom" text="From"/>
                    <TableColumn fx:id="colDepartureTime" text="Departure Time"/>
                    <TableColumn fx:id="colTo" text="To"/>
                    <TableColumn fx:id="colArrivalTime" text="Duration"/>
                    <TableColumn fx:id="colType" text="Type"/>
                    <TableColumn fx:id="colPrice" text="Price"/>
                </columns>
            </TableView>

            <HBox spacing="20" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="5" right="10" bottom="10" left="10" />
                </padding>
                <Label text="Total Duration:"/>
                <Label fx:id="lblTotalDuration"/>
                <Label text="Total Price:"/>
                <Label fx:id="lblTotalPrice"/>
            </HBox>

            <Canvas fx:id="routeCanvas" width="600.0" height="300.0" />
        </VBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button text="TOP 5 ROUTES" onAction="#onTop5Clicked"/>
            <Button text="BUY A TICKET" onAction="#onBuyTicketClicked"/>
        </HBox>
    </bottom>

</BorderPane>

